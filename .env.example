# ─── agentec-openclaw-stack .env ─────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores reales antes de usar bootstrap.sh
# NUNCA subas .env a git.
#
# Generador de token: openssl rand -hex 32

# ─── OpenClaw ────────────────────────────────────────────────────────────────
# Token de autenticación del gateway (OBLIGATORIO)
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Token de autenticación del MCP server (OBLIGATORIO)
AGENTEC_MCP_AUTH_TOKEN=change-me-to-a-long-random-token

# Imagen Docker de OpenClaw
# IMPORTANTE: usa una versión específica, no 'latest', para evitar actualizaciones
# silenciosas que puedan romper el stack.
# Para actualizar:
#   1. Revisa el CHANGELOG de OpenClaw: https://github.com/openclaw/openclaw/releases
#   2. Prueba en entorno de staging ANTES de producción
#   3. Actualiza este valor y ejecuta: ./scripts/bootstrap.sh
# Para obtener el digest de latest: docker inspect ghcr.io/openclaw/openclaw:latest --format '{{index .RepoDigests 0}}'
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw@sha256:<digest>  # pin a versión específica

# Zona horaria
OPENCLAW_TZ=America/Mexico_City

# Puertos (cambiar si hay conflictos)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
AGENTEC_MCP_PORT=3002
AGENTEC_MCP_PY_PORT=3102
AGENTEC_SHADOW_MODE=0

# URL interna del MCP para OpenClaw dentro de Docker.
# Default recomendado (MCP central del catálogo):
# AGENTEC_MCP_SERVER_URL_INTERNAL=http://agentec-mcp-server:3000/mcp
# Override opcional para desarrollo local:
# AGENTEC_MCP_SERVER_URL_INTERNAL=http://host.docker.internal:3000/mcp

# Timeout / logging MCP Python (shadow)
AGENTEC_MCP_TIMEOUT_SECONDS=20
AGENTEC_MCP_MAX_TIMEOUT_SECONDS=120
AGENTEC_MCP_LOG_LEVEL=INFO

# Backend de transición para web_login_playwright (Paso 9/10)
# auto: intenta Python y si falla usa wrapper legacy Node
# python: fuerza backend Python
# node: fuerza wrapper legacy Node
AGENTEC_WEB_LOGIN_BACKEND=auto
AGENTEC_WEB_LOGIN_PY_ENTRYPOINT=/app/external-tools/web-login-playwright-py/src/main.py
AGENTEC_WEB_LOGIN_NODE_ENTRYPOINT=/app/external-tools/web-login-playwright/scripts/python-wrapper.js

# Golden tests Node vs Python (Paso 11)
AGENTEC_GOLDEN_TEST=0
AGENTEC_GOLDEN_MAX_LATENCY_DELTA_MS=3000
AGENTEC_GOLDEN_MAX_PY_TO_NODE_RATIO=2.5

# Paso 13: regresión + carga básica (staging)
AGENTEC_REGRESSION_ITERATIONS_LIST=10
AGENTEC_REGRESSION_ITERATIONS_CALL=10
AGENTEC_REGRESSION_MAX_ERROR_RATE=0.05
AGENTEC_LOAD_TOTAL_REQUESTS=30
AGENTEC_LOAD_CONCURRENCY=6
AGENTEC_LOAD_MAX_ERROR_RATE=0.10
AGENTEC_LOAD_P95_TARGET_MS=3000

# Modo de bind del gateway
# loopback = solo accesible desde este equipo (RECOMENDADO para uso personal)
# lan      = accesible desde la red local (solo si necesitas acceder desde otro dispositivo)
OPENCLAW_GATEWAY_BIND=loopback

# Rutas persistentes del host montadas dentro del contenedor
# Usa rutas relativas al repo para máxima portabilidad entre Linux/macOS/WSL/Windows.
OPENCLAW_CONFIG_DIR=../.openclaw
OPENCLAW_WORKSPACE_DIR=../.openclaw/workspace

# Directorio de artefactos generados por tools (capturas, resultados)
AGENTEC_ARTIFACTS_DIR=../artifacts
AGENTEC_SKILLS_DIR=../agentec-skills/skills
AGENTEC_TOOLS_DIR=../agentec-tools/tools
AGENTEC_STACK_CONFIG_DIR=./config
AGENTEC_STACK_ENV_FILE=./.env

# Store persistente de tokens locales para tools Graph
AGENTEC_GRAPH_TOKEN_STORE_DIR=../.agentec-graph-tokens

# ─── Configuración reusable: web login ───────────────────────────────────────
AGENTEC_WEB_LOGIN_PROFILE=demo-login
# Override opcional de archivo de perfiles. Si se deja vacío, usa:
#   <AGENTEC_STACK_CONFIG_DIR>/tools/web-login/profiles.json
AGENTEC_WEB_LOGIN_CONFIG_FILE=

# ─── Configuración reusable: Microsoft Graph ─────────────────────────────────
# Cambia tenant solo cambiando este valor: personal | tec
AGENTEC_GRAPH_PROFILE=personal
AGENTEC_GRAPH_DEFAULT_TENANT_ID=
AGENTEC_GRAPH_DEFAULT_CLIENT_ID=
AGENTEC_GRAPH_AUTHORITY_HOST=https://login.microsoftonline.com
AGENTEC_GRAPH_ALLOW_TENANT_OVERRIDE=0

# Modo de autenticación Graph:
# - devicecode: flujo actual (compatibilidad)
# - oauth_redirect: flujo objetivo con redirect URI local
AGENTEC_GRAPH_AUTH_MODE=oauth_redirect
AGENTEC_GRAPH_REDIRECT_URI=http://localhost:18789/auth/callback
# Solo si se usa confidential client (recomendado en políticas estrictas)
AGENTEC_GRAPH_CLIENT_SECRET=

# Fallback de scopes (se recomienda gestionarlos desde profiles.json por tenant)
AGENTEC_GRAPH_MAIL_SCOPES=openid profile email offline_access User.Read Mail.ReadWrite Mail.Send
AGENTEC_GRAPH_FILES_SCOPES=openid profile email offline_access User.Read Files.ReadWrite Sites.Read.All Sites.ReadWrite.All
# Override opcional de archivo de perfiles. Si se deja vacío, usa:
#   <AGENTEC_STACK_CONFIG_DIR>/tools/graph/profiles.json
AGENTEC_GRAPH_CONFIG_FILE=

# ─── Modelo seleccionado en bootstrap ────────────────────────────────────────
# Esta variable la escribe bootstrap.sh automáticamente.
# Formato: <proveedor>/<modelo>  (ej: openrouter/anthropic/claude-sonnet-4-5)
OPENCLAW_MODEL_PRIMARY=placeholder

# ─── Proveedores de modelos (define al menos uno) ────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# ─── Provider web de Claude (opcional) ───────────────────────────────────────
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# ─── Seguridad extra del gateway (opcional) ──────────────────────────────────
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

