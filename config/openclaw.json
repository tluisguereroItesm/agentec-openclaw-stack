{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace"
    }
  },
  "mcp": {
    "servers": {
      "agentec": {
        "url": "http://agentec-mcp-server:3000/mcp",
        "transport": "streamable-http",
        "headers": {
          "Authorization": "Bearer ${AGENTEC_MCP_AUTH_TOKEN}"
        }
      }
    }
  },
  "tools": {
    "profile": "full",
    "alsoAllow": [
      "bundle-mcp"
    ]
  },
  "skills": {
    "load": {
      "extraDirs": ["~/.openclaw/skills"]
    }
  }
}
